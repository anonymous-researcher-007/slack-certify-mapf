# Default: treat all files as text and normalize to LF on commit.
* text=auto eol=lf
# Explicit text-with-LF for source / config files.
*.py     text eol=lf diff=python
*.pyi    text eol=lf diff=python
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.sh     text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
# Binary assets — never auto-LF and never diffed as text.
*.map  binary
*.scen binary
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.npz  binary
*.npy  binary
*.parquet binary
src/slackcertify/solvers/external_bin/lacam_star filter=lfs diff=lfs merge=lfs -text
src/slackcertify/solvers/external_bin/kottinger filter=lfs diff=lfs merge=lfs -text
src/slackcertify/solvers/external_bin/eecbs filter=lfs diff=lfs merge=lfs -text
src/slackcertify/solvers/external_bin/pibt filter=lfs diff=lfs merge=lfs -text
